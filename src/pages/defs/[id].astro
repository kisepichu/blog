---
import { getCollection, render } from 'astro:content'
import { buildAliasMap } from '@/lib/build/alias-map'
import { FILTER_DRAFTS } from '@/config/env'
import { getBacklinkGraph } from '@/lib/build/backlink-graph'
import Layout from '@/components/Layout.astro'
import Breadcrumb from '@/components/Breadcrumb.astro'
import TagBadge from '@/components/TagBadge.astro'
import Backlinks from '@/components/Backlinks.astro'
import GiscusComments from '@/components/GiscusComments.astro'

export async function getStaticPaths() {
  const allDefs = await getCollection('defs')
  const allPosts = await getCollection('posts')

  const defs = FILTER_DRAFTS
    ? allDefs.filter((d) => d.data.status === 'published')
    : allDefs
  const posts = FILTER_DRAFTS
    ? allPosts.filter((p) => p.data.status === 'published')
    : allPosts

  // alias map を構築 (backlink 解決に使用)
  const aliasMap = buildAliasMap(
    defs.map((d) => ({ id: d.id, title: d.data.title, aliases: d.data.aliases })),
  )

  // backlink グラフ構築用エントリ
  const entries = [
    ...defs.map((d) => ({
      type: 'definition' as const,
      slug: d.id,
      title: d.data.title,
      body: d.body ?? '',
    })),
    ...posts.map((p) => ({
      type: 'post' as const,
      slug: p.id,
      title: p.data.title,
      body: p.body ?? '',
    })),
  ]

  const backlinkGraph = await getBacklinkGraph(entries, aliasMap)

  return defs.map((def) => ({
    params: { id: def.id },
    props: {
      def,
      backlinks: backlinkGraph[def.id] ?? [],
    },
  }))
}

const { def, backlinks } = Astro.props
const { Content } = await render(def)

const base = import.meta.env.BASE_URL.replace(/\/$/, '')

// id・title・english を除いたエイリアス一覧 (いずれもページ上で別途表示済み)
const displayAliases = def.data.aliases.filter(
  (a) => a !== def.id && a !== def.data.title && a !== def.data.english
)
---

<Layout title={def.data.title} activePage="def">
  <div class="container--narrow">
    <Breadcrumb
      items={[
        { label: 'Home', href: `${base}/` },
        { label: 'Defs' },
        { label: def.data.title },
      ]}
    />

    <header class="def-header">
      <div class="def-header__type">定義 / DEFINITION</div>
      <div class="def-title-row">
        <h1 class="def-title">{def.data.title}</h1>
        <span class="def-id-badge">{def.id}</span>
        {def.data.english && (
          <span class="def-english def-aliases">{def.data.english}</span>
        )}
        {displayAliases.length > 0 && (
          <span class="def-aliases">別名: {displayAliases.join(', ')}</span>
        )}
      </div>
      {def.data.tags.length > 0 && (
        <div class="def-tags">
          {def.data.tags.map((tag) => (
            <TagBadge tag={tag} href={`${base}/tags/${tag}`} />
          ))}
        </div>
      )}
    </header>

    <!-- Pagefind フィルタ用 (1 タグ 1 span) -->
    <span data-pagefind-filter="type:definition" hidden></span>
    {def.data.tags.map(t => (
      <span data-pagefind-filter={`tags:${t}`} hidden></span>
    ))}

    <!-- Pagefind 表示メタ用 -->
    <span data-pagefind-meta="type:definition" hidden></span>
    {def.data.tags.length > 0 && (
      <span data-pagefind-meta={`tags:${def.data.tags.join(',')}`} hidden></span>
    )}
    {def.data.aliases.length > 0 && (
      <span data-pagefind-meta={`aliases:${def.data.aliases.join(',')}`} hidden></span>
    )}

    <div class="def-content prose">
      <Content />
    </div>

    <div data-pagefind-ignore>
      <Backlinks items={backlinks} />
    </div>
    <GiscusComments />
  </div>
</Layout>

<style>
  .def-header {
    margin-bottom: 1.5rem;
  }
  .def-header__type {
    font-family: var(--font-ui);
    font-size: 0.68rem;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }
  .def-title-row {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }
  .def-title {
    font-size: 1.55rem;
  }
  .def-id-badge {
    font-family: var(--font-code);
    font-size: 0.78rem;
    color: var(--text-faint);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    padding: 1px 8px;
  }
  .def-aliases {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: var(--font-ui);
  }
  .def-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .def-content {
    margin-top: 0;
  }
</style>
