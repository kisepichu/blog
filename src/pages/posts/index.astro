---
import { getCollection } from 'astro:content'
import Layout from '@/components/Layout.astro'
import Breadcrumb from '@/components/Breadcrumb.astro'
import PostCard from '@/components/PostCard.astro'
import { getVisiblePostsSorted } from '@/lib/posts'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const PAGE_SIZE = 10

const allPosts = await getCollection('posts')
const allSeries = await getCollection('series')

const posts = getVisiblePostsSorted(allPosts, import.meta.env.PROD)

const visibleSeries = import.meta.env.PROD
  ? allSeries.filter((s) => s.data.status === 'published')
  : allSeries
const seriesTitleMap = new Map(visibleSeries.map((s) => [s.id, s.data.title]))

const totalPages = Math.ceil(posts.length / PAGE_SIZE)
const pagePosts = posts.slice(0, PAGE_SIZE)
---

<Layout title="Posts" activePage="post">
  <div class="container--narrow" data-pagefind-ignore>
    <Breadcrumb items={[
      { label: 'Home', href: `${base}/` },
      { label: 'Posts' },
    ]} />

    <h1 class="posts-heading">Posts</h1>

    {pagePosts.map((post) => (
      <PostCard
        title={post.data.title}
        href={`${base}/posts/${encodeURIComponent(post.id)}`}
        date={post.data.date}
        tags={post.data.tags}
        series={post.data.series && seriesTitleMap.has(post.data.series) ? seriesTitleMap.get(post.data.series) : undefined}
        seriesOrder={post.data.series_order}
      />
    ))}

    {totalPages > 1 && (
      <nav class="posts-pagination" aria-label="ページネーション">
        <span class="posts-pagination__btn posts-pagination__btn--disabled">← 前のページ</span>
        <span class="posts-pagination__info">1 / {totalPages}</span>
        <a class="posts-pagination__btn" href={`${base}/posts/page/2`}>次のページ →</a>
      </nav>
    )}
  </div>
</Layout>
