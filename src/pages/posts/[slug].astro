---
import { getCollection, render, type CollectionEntry } from 'astro:content'
import { buildAliasMap } from '@/lib/build/alias-map'
import { FILTER_DRAFTS } from '@/config/env'
import { getBacklinkGraph } from '@/lib/build/backlink-graph'
import Layout from '@/components/Layout.astro'
import Breadcrumb from '@/components/Breadcrumb.astro'
import TagBadge from '@/components/TagBadge.astro'
import Backlinks from '@/components/Backlinks.astro'
import GiscusComments from '@/components/GiscusComments.astro'

export async function getStaticPaths() {
  const allPosts = await getCollection('posts')
  const allDefs = await getCollection('defs')
  const allSeries = await getCollection('series')

  const posts = FILTER_DRAFTS
    ? allPosts.filter((p) => p.data.status === 'published')
    : allPosts
  const defs = FILTER_DRAFTS
    ? allDefs.filter((d) => d.data.status === 'published')
    : allDefs

  const aliasMap = buildAliasMap(
    defs.map((d) => ({ id: d.id, aliases: d.data.aliases })),
  )

  const entries = [
    ...defs.map((d) => ({ type: 'definition' as const, slug: d.id, title: d.data.title, body: d.body ?? '' })),
    ...posts.map((p) => ({ type: 'post' as const, slug: p.id, title: p.data.title, body: p.body ?? '' })),
  ]

  const backlinkGraph = await getBacklinkGraph(entries, aliasMap)

  const visibleSeries = FILTER_DRAFTS
    ? allSeries.filter((s) => s.data.status === 'published')
    : allSeries
  const seriesTitleMap = new Map(visibleSeries.map((s) => [s.id, s.data.title]))

  // series ごとに posts を事前グループ化して O(n log n) に最適化
  type PostNav = { prev: CollectionEntry<'posts'> | null; next: CollectionEntry<'posts'> | null }
  const seriesNavByPostId = new Map<string, PostNav>()
  const seriesGroupMap = new Map<string, CollectionEntry<'posts'>[]>()

  for (const post of posts) {
    const seriesId = post.data.series
    if (!seriesId || !seriesTitleMap.has(seriesId)) continue
    const group = seriesGroupMap.get(seriesId) ?? []
    group.push(post)
    seriesGroupMap.set(seriesId, group)
  }
  for (const group of seriesGroupMap.values()) {
    group.sort((a, b) => (a.data.series_order ?? 0) - (b.data.series_order ?? 0))
    for (const [idx, p] of group.entries()) {
      seriesNavByPostId.set(p.id, { prev: group[idx - 1] ?? null, next: group[idx + 1] ?? null })
    }
  }

  return posts.map((post) => {
    const seriesNav =
      post.data.series && seriesTitleMap.has(post.data.series)
        ? (seriesNavByPostId.get(post.id) ?? { prev: null, next: null })
        : null

    return {
      params: { slug: post.id },
      props: {
        post,
        backlinks: backlinkGraph[post.id] ?? [],
        // series が draft/未登録の場合は null にしてバナー非表示 (prod での 404 リンク防止)
        seriesTitle: post.data.series ? (seriesTitleMap.get(post.data.series) ?? null) : null,
        seriesNav,
      },
    }
  })
}

const { post, backlinks, seriesTitle, seriesNav } = Astro.props
const { Content } = await render(post)
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<Layout title={post.data.title} activePage="post">
  <div class="container--narrow">
    <Breadcrumb items={[
      { label: 'Home', href: `${base}/` },
      { label: 'Posts', href: `${base}/posts` },
      { label: post.data.title },
    ]} />

    {post.data.series && seriesTitle && (
      <div class="series-banner">
        <span>シリーズ:</span>
        <a href={`${base}/series/${encodeURIComponent(post.data.series)}`}>{seriesTitle}</a>
        <span class="series-banner__order">#{post.data.series_order}</span>
      </div>
    )}

    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-meta">
        {post.data.date && <span class="post-date">{post.data.date}</span>}
        {post.data.tags.length > 0 && (
          <div class="post-tags">
            {post.data.tags.map((tag) => (
              <TagBadge tag={tag} href={`${base}/tags/${tag}`} />
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- Pagefind フィルタ用 (1 タグ 1 span) -->
    <span data-pagefind-filter="type:post" hidden></span>
    {post.data.tags.map(t => (
      <span data-pagefind-filter={`tags:${t}`} hidden></span>
    ))}

    <!-- Pagefind 表示メタ用 -->
    <span data-pagefind-meta="type:post" hidden></span>
    {post.data.tags.length > 0 && (
      <span data-pagefind-meta={`tags:${post.data.tags.join(',')}`} hidden></span>
    )}
    {post.data.date && (
      <span data-pagefind-meta={`date:${post.data.date}`} hidden></span>
    )}
    {seriesTitle && (
      <span data-pagefind-meta={`series:${post.data.series}`} hidden></span>
    )}

    <article class="prose" data-pagefind-body>
      <Content />
    </article>

    {seriesNav && (seriesNav.prev || seriesNav.next) && (
      <nav class="series-nav" aria-label="シリーズナビゲーション">
        {seriesNav.prev && (
          <a class="series-nav__btn series-nav__btn--prev" href={`${base}/posts/${encodeURIComponent(seriesNav.prev.id)}`}>
            <span>←</span><span>{seriesNav.prev.data.title}</span>
          </a>
        )}
        {seriesNav.next && (
          <a class="series-nav__btn series-nav__btn--next" href={`${base}/posts/${encodeURIComponent(seriesNav.next.id)}`}>
            <span>{seriesNav.next.data.title}</span><span>→</span>
          </a>
        )}
      </nav>
    )}

    <div data-pagefind-ignore>
      <Backlinks items={backlinks} />
    </div>
    <GiscusComments />
  </div>
</Layout>

<style>
  .post-header { margin-bottom: 2.2rem; }
  .post-title { font-size: 1.55rem; letter-spacing: 0.01em; line-height: 1.35; margin-bottom: 0.7rem; }
  .post-meta { display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap; }
  .post-date { font-family: var(--font-ui); font-size: 0.72rem; color: var(--text-faint); }
  .post-tags { display: flex; gap: 0.35rem; flex-wrap: wrap; }
  .series-banner {
    display: flex; align-items: center; gap: 0.6rem;
    font-family: var(--font-ui); font-size: 0.72rem;
    background: var(--lav-bg); border: 1px solid var(--lav-b);
    border-radius: var(--r-sm); padding: 0.4rem 0.9rem;
    margin-bottom: 1.2rem; color: var(--lav);
  }
  .series-banner__order { color: var(--lav); opacity: 0.6; }
</style>
