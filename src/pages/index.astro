---
import { getCollection } from 'astro:content'
import Layout from '@/components/Layout.astro'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const allPosts = await getCollection('posts')
const posts = import.meta.env.PROD
  ? allPosts.filter((e) => e.data.status === 'published')
  : allPosts
---

<Layout title="Blog" activePage="home">
  <div class="container">
    <h1>Blog</h1>

    <section>
      <h2>最新記事</h2>
      {posts.length === 0 ? (
        <p>記事はまだありません。</p>
      ) : (
        <ul>
          {posts.map((post) => (
            <li>
              <a href={`${base}/posts/${post.id}`}>{post.data.title}</a>
            </li>
          ))}
        </ul>
      )}
    </section>
  </div>
</Layout>
