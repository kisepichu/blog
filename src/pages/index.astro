---
import { getCollection } from 'astro:content'
import '@/styles/global.css'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const allPosts = await getCollection('posts')
const posts = import.meta.env.PROD
  ? allPosts.filter((e) => e.data.status === 'published')
  : allPosts
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Blog</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DotGothic16&family=JetBrains+Mono:wght@400;700&family=M+PLUS+Rounded+1c:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main>
      <h1>Blog</h1>

      <section>
        <h2>最新記事</h2>
        {posts.length === 0 ? (
          <p>記事はまだありません。</p>
        ) : (
          <ul>
            {posts.map((post) => (
              <li>
                <a href={`${base}/posts/${post.id}`}>{post.data.title}</a>
              </li>
            ))}
          </ul>
        )}
      </section>
    </main>
  </body>
</html>
