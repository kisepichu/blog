---
const siteOrigin = import.meta.env.SITE ?? Astro.url.origin
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`
const themeUrl = new URL(`${basePath}giscus-theme.css`, siteOrigin).toString()

// giscus の HTTPS iframe は HTTP URL を Mixed Content としてブロックする。
// SITE 未設定時は Astro.url.origin が使われ HTTP URL になりうるため、https:// のみカスタムテーマを使用する。
const useCustomTheme = themeUrl.startsWith('https://')
const theme = useCustomTheme ? themeUrl : 'catppuccin_latte'
---
<div class="giscus-wrapper">
  <script
    is:inline
    src="https://giscus.app/client.js"
    data-repo="kisepichu/blog"
    data-repo-id="R_kgDOSGOExQ"
    data-category="Announcements"
    data-category-id="DIC_kwDOSGOExc4C7w7r"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme={theme}
    data-lang="ja"
    crossorigin="anonymous"
    async
  ></script>

  {useCustomTheme && (
    <script is:inline define:vars={{ themeUrl }}>
      // カスタムテーマ CSS が取得できない場合 catppuccin_latte にフォールバック
      fetch(themeUrl, { method: 'HEAD' })
        .then((res) => {
          if (!res.ok) throw new Error(`Failed to load giscus theme CSS: ${res.status}`)
        })
        .catch(() => {
          function sendFallback(iframe) {
            iframe.contentWindow.postMessage(
              { giscus: { setConfig: { theme: 'catppuccin_latte' } } },
              'https://giscus.app'
            )
          }
          function applyFallback() {
            const iframe = document.querySelector('iframe.giscus-frame')
            if (!iframe) return
            iframe.addEventListener('load', () => sendFallback(iframe), { once: true })
            // 既にロード済みの場合に備えて少し遅延して送信
            setTimeout(() => sendFallback(iframe), 200)
          }
          const wrapper = document.querySelector('.giscus-wrapper')
          const iframe = wrapper && wrapper.querySelector('iframe.giscus-frame')
          if (iframe) {
            applyFallback()
          } else if (wrapper) {
            // iframe 未生成の場合は wrapper 内に限定して監視し、5 秒でタイムアウト
            const obs = new MutationObserver(() => {
              if (wrapper.querySelector('iframe.giscus-frame')) {
                obs.disconnect()
                applyFallback()
              }
            })
            obs.observe(wrapper, { childList: true, subtree: true })
            setTimeout(() => obs.disconnect(), 5000)
          }
        })
    </script>
  )}
</div>

<style>
  .giscus-wrapper {
    margin-top: 3rem;
  }
</style>
