---
interface BreadcrumbItem {
  label: string
  href?: string
}

interface Props {
  items: BreadcrumbItem[]
}

const { items } = Astro.props
---

<nav class="breadcrumb" aria-label="パンくずリスト">
  {items.map((item, i) => (
    <>
      {i > 0 && <span class="breadcrumb__sep">›</span>}
      {item.href
        ? <a href={item.href}>{item.label}</a>
        : <span>{item.label}</span>
      }
    </>
  ))}
</nav>
